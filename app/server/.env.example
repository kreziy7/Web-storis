PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/smart-reminder
JWT_ACCESS_SECRET=your_jwt_access_secret_should_be_long_and_secure
JWT_REFRESH_SECRET=your_jwt_refresh_secret_should_be_long_and_secure
CLIENT_URL=http://localhost:5173

# VAPID Keys for Web Push Notifications
# Generate these with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:example@yourdomain.com
